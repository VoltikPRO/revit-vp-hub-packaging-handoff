<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Copied from agent UI: Secure Precision UI tokens (Light). -->
    <SolidColorBrush x:Key="Brush.Bg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFF8FAFC" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF1F5F9" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFE2E8F0" />

    <SolidColorBrush x:Key="Brush.Fg" Color="#FF0F172A" />
    <SolidColorBrush x:Key="Brush.FgSecondary" Color="#FF334155" />
    <SolidColorBrush x:Key="Brush.Muted" Color="#FF64748B" />

    <SolidColorBrush x:Key="Brush.Accent" Color="#FF1D4ED8" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF1E40AF" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF1E3A8A" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#FFEFF6FF" />
    <SolidColorBrush x:Key="Brush.AccentTint" Color="#FFDBEAFE" />

    <SolidColorBrush x:Key="Brush.Success" Color="#FF16A34A" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFF59E0B" />
    <SolidColorBrush x:Key="Brush.Error" Color="#FFDC2626" />
    <SolidColorBrush x:Key="Brush.Info" Color="#FF0EA5E9" />

    <CornerRadius x:Key="Radius.Sm">4</CornerRadius>

