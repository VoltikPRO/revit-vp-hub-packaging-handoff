<Window x:Class="LicensingSystem.Revit.LicenseProbe.About.LicenseProbeAboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About — License Probe"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="560"
        Background="{DynamicResource Brush.Bg}">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="120" Click="OnCloseClick" Style="{StaticResource Button.Primary}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,8">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding BrandTitle}" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{Binding ProductDisplayName}" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,10,0,0"
                                   Foreground="{DynamicResource Brush.FgSecondary}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Versions" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Revit" Foreground="{DynamicResource Brush.Muted}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RevitVersion}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Product code" Foreground="{DynamicResource Brush.Muted}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProductCode}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Add-in build" Foreground="{DynamicResource Brush.Muted}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AddinBuild}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Assembly path" Foreground="{DynamicResource Brush.Muted}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AddinAssemblyPath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="CorrelationId" Foreground="{DynamicResource Brush.Muted}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CorrelationId}" TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Agent status" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                        <TextBlock TextWrapping="Wrap">
                            <Run Text="{Binding AgentStatusSummary}" />
                        </TextBlock>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding AgentStatusDetail}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.Muted}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>

